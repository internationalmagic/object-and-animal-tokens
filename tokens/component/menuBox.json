{
  "component": {
    "menuBox": {
      "dimension": {
        "padding": {
          "x": {
            "$value": "{app.dimension.component.spacing.2}",
            "$type": "dimension"
          },
          "y": {
            "$value": "{app.dimension.component.spacing.2}",
            "$type": "dimension"
          }
        },
        "gap": {
          "default": {
            "$value": "0",
            "$type": "dimension"
          }
        },
        "blur": {
          "default": {
            "$value": "0.5rem",
            "$type": "dimension"
          }
        },
        "radius": {
          "xs": {
            "$value": "{app.dimension.component.radius.default.md}",
            "$type": "dimension"
          },
          "sm": {
            "$value": "{app.dimension.component.radius.default.lg}",
            "$type": "dimension"
          },
          "md": {
            "$value": "{app.dimension.component.radius.default.xl}",
            "$type": "dimension"
          },
          "lg": {
            "$value": "{app.dimension.component.radius.default.2xl}",
            "$type": "dimension"
          }
        },
        "border": {
          "default": {
            "$value": "{app.dimension.component.border.default}",
            "$type": "dimension"
          }
        }
      },
      "color": {
        "bg": {
          "$value": "{app.color.component.primary.bg.inverted.default}",
          "$type": "color"
        },
        "border": {
          "$value": "{app.color.component.primary.border.translucent.default}",
          "$type": "color"
        }
      },
      "boxShadow": {
        "default": {
          "$value": "none",
          "$type": "boxShadow"
        }
      }
    }
  }
}
